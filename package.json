{
  "name": "openclaw-tracing",
  "version": "0.3.0",
  "description": "Agent execution tracing plugin for OpenClaw — tree-view CLI + web UI for tool calls, LLM invocations, and sub-agent relationships",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "tsc --noEmit"
  },
  "devDependencies": {
    "openclaw": "*",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.1.0"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  },
  "files": [
    "index.ts",
    "src/",
    "openclaw.plugin.json"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fengsxy/openclaw-tracing.git"
  },
  "keywords": [
    "openclaw",
    "tracing",
    "agent",
    "plugin"
  ],
  "optionalDependencies": {
    "@duckdb/node-api": "^1.5.0-r.1"
  }
}
